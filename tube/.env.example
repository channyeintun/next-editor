# --- Production (B1: editor reverse-proxied under this same origin) ---
# Leave VITE_EDITOR_BASE empty so the iframe loads /code same-origin and inherits
# cross-origin isolation (WebContainer works). The reverse proxy is configured in
# Caddyfile / vercel.json, not here.
VITE_EDITOR_BASE=

# --- Local dev only ---
# Where Vite proxies the editor's paths (/code, /assets, /fonts, /logo.*).
# Run the editor's built preview in the repo root so its hashed /assets/* don't
# collide with tube's dev module paths:  bun run build && bun run preview
VITE_EDITOR_PROXY_TARGET=http://localhost:4173
