# Reverse-proxy the editor under the tube origin so the lesson iframe is
# same-origin and inherits cross-origin isolation (required for WebContainer).
# Set EDITOR_UPSTREAM to the editor deployment, e.g. https://nexteditor.dev
tube.nexteditor.dev {
	encode zstd gzip

	# Cross-origin isolation for the whole origin (gallery + embedded editor).
	header {
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Embedder-Policy "require-corp"
	}

	# Editor app paths → proxied to the editor build. Because the response is
	# delivered as this origin, its assets are same-origin and satisfy COEP with
	# no CORS/CORP juggling.
	@editor path /code /code/* /assets/* /fonts/* /logo.svg /logo.png
	reverse_proxy @editor {$EDITOR_UPSTREAM} {
		header_up Host {upstream_hostport}
	}

	# Gallery SPA + lesson files (.ne/.vtt/thumbnails under /lessons/, gallery
	# bundles under /gallery-assets/) are served statically from this origin.
	root * /srv
	try_files {path} /index.html
	file_server
}
