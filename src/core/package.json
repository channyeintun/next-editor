{
  "name": "use-next-editor",
  "version": "3.2.0",
  "description": "A powerful React hook for recording and replaying Monaco Editor interactions",
  "main": "./dist/index.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint \"src/**/*.{ts,tsx}\"",
    "clean": "rimraf dist",
    "publish": "./publish.sh",
    "asbuild:debug": "asc assembly/index.ts --target debug --outFile build/next-editor.debug.wasm",
    "asbuild:release": "asc assembly/index.ts --target release --outFile build/next-editor.wasm",
    "asbuild": "npm run asbuild:release && mkdir -p dist && cp build/next-editor.wasm dist/ && cp build/next-editor.wasm ../../public/",
    "start": "npx serve ."
  },
  "keywords": [
    "react",
    "hook",
    "monaco",
    "editor",
    "recording",
    "replay",
    "next-editor",
    "typescript",
    "code-editor",
    "screen-recording",
    "tutorial"
  ],
  "author": {
    "name": "Chan Nyein Tun",
    "email": "chanyeintun@gmail.com"
  },
  "license": "MIT",
  "peerDependencies": {
    "@monaco-editor/react": ">=4.0.0",
    "react": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "@monaco-editor/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@types/pako": "^2.0.4",
    "@types/react": "^18.2.56",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "@vitest/browser": "^4.0.18",
    "asbuild": "^0.2.0",
    "assemblyscript": "^0.28.9",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jsdom": "^27.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^5.0.5",
    "rollup": "^4.55.1",
    "rollup-plugin-dts": "^6.3.0",
    "rollup-plugin-postcss": "^4.0.2",
    "tslib": "^2.8.1",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "monaco-editor": "^0.52.2",
    "pako": "^2.1.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module"
}