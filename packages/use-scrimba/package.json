{
  "name": "use-scrimba",
  "version": "1.0.8",
  "description": "A powerful React hook for recording and replaying Monaco Editor interactions with Scrimba-like functionality",
  "main": "./dist/index.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "jest",
    "test:watch": "jest --watch",
    "type-check": "tsc --noEmit",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint \"src/**/*.{ts,tsx}\"",
    "clean": "rimraf dist",
    "publish": "./publish.sh",
    "test-local": "./scripts/test-simple.sh"
  },
  "keywords": [
    "react",
    "hook",
    "monaco",
    "editor",
    "recording",
    "replay",
    "scrimba",
    "typescript",
    "code-editor",
    "screen-recording",
    "tutorial"
  ],
  "author": {
    "name": "Chan Nyein Tun",
    "email": "chanyeintun@gmail.com"
  },
  "license": "MIT",
  "peerDependencies": {
    "@monaco-editor/react": ">=4.0.0",
    "react": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "@monaco-editor/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/react-hooks": "^8.0.1",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.56",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^5.0.5",
    "rollup": "^4.12.0",
    "rollup-plugin-dts": "^6.1.0",
    "ts-jest": "^29.1.2",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.8.2"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
