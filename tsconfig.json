{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "paths": {
      // monaco-editor 0.55 added an `exports` map that no longer resolves the
      // extensionless deep path `@monaco-editor/react`'s own .d.ts imports
      // (`monaco-editor/esm/vs/editor/editor.api`), collapsing its `Monaco`
      // type to `any`. Point that exact specifier at the real declarations.
      "monaco-editor/esm/vs/editor/editor.api": [
        "./node_modules/monaco-editor/esm/vs/editor/editor.api.d.ts"
      ],
      // Resolve the tube workspace package to its source so it's compiled as
      // first-class app code (JSX transform, Tailwind scan, type-checked).
      "@next-editor/tube": ["./tube/src/index.tsx"]
    },
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "allowJs": false,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  // The diff-match-patch codec lives in src/core/dmp as a Rust crate (no .ts),
  // so tsc ignores it; no exclude needed.
  "include": ["src", "vite.config.ts"]
}
