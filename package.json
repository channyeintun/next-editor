{
  "name": "next-editor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "npm run asbuild && tsc -b && vite build",
    "asbuild:debug": "asc src/core/assembly/index.ts --target debug",
    "asbuild:release": "asc src/core/assembly/index.ts --target release",
    "asbuild": "npm run asbuild:release",
    "clean:core": "rimraf src/core/dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint . --react-plugin --vitest-plugin --ignore-pattern dist --ignore-pattern public --deny-warnings",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@types/pako": "^2.0.4",
    "@webcontainer/api": "^1.6.4",
    "@xstate/react": "^6.0.0",
    "animejs": "^4.3.5",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.562.0",
    "motion": "^12.26.2",
    "pako": "^2.1.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.12.0",
    "reveal.js": "^5.2.1",
    "superjson": "^2.2.6",
    "xstate": "^5.25.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.0.9",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@types/reveal.js": "^5.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.0.18",
    "asbuild": "^0.2.0",
    "assemblyscript": "^0.28.9",
    "autoprefixer": "^10.4.23",
    "jsdom": "^27.4.0",
    "monaco-editor": "^0.52.2",
    "oxlint": "^1.63.0",
    "postcss": "^8.5.6",
    "rimraf": "^6.1.2",
    "rolldown": "^1.0.0",
    "tailwindcss": "^4.1.18",
    "tslib": "^2.8.1",
    "typescript": "~5.8.3",
    "vite": "^8.0.11",
    "vite-plugin-checker": "^0.12.0",
    "vitest": "^4.0.18"
  }
}
